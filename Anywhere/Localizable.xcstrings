    "Block ads and trackers at the network level for a cleaner browsing experience." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حظر الإعلانات والمتتبعات على مستوى الشبكة لتجربة تصفح أنظف."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bloquea anuncios y rastreadores a nivel de red para una experiencia de navegación más limpia."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
