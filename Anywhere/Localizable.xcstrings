            "value" : "وجّه حركة المرور إلى بلدك مباشرة، متجاوزًا البروكسي للوصول المحلي الأسرع."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dirige el tráfico a tu país directamente, evitando el proxy para un acceso local más rápido."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ترافیک به کشور خود را مستقیماً هدایت کنید و پروکسی را برای دسترسی سریع‌تر دور بزنید."
          }
        },
        "my" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ပိုမြန်သော ပြည်တွင်းဝင်ရောက်မှုအတွက် ပရောက်စီကို ကျော်ပြီး သင့်နိုင်ငံသို့ တိုက်ရိုက်လမ်းကြောင်းပေးပါ။"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Направляйте трафик в вашу страну напрямую, минуя прокси для более быстрого локального доступа."
          }
        },
        "tk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ýerli elýeterliligi çaltlaşdyrmak üçin proksi aýlanyp, traffigi öz ýurduňyza gönüden-göni ugrugyň."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Định tuyến lưu lượng đến quốc gia của bạn trực tiếp, bỏ qua proxy để truy cập nội địa nhanh hơn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
