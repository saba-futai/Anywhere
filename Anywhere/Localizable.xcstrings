            "value" : "برای کشف و ارتقاء خودکار به سرورهای DNS رمزنگاری‌شده، خالی بگذارید."
          }
        },
        "my" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ကုဒ်ဝှက်ထားသော DNS ဆာဗာများကို အလိုအလျောက် ရှာဖွေပြီး အဆင့်မြှင့်ရန် ဗလာထားပါ။"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Оставьте пустым для автоматического обнаружения и перехода на зашифрованные DNS-серверы."
          }
        },
        "tk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Şifrlenen DNS serwerleri awtomatiki tapmak we geçmek üçin boş goýuň."
          }
