    "All trademarks, service marks, and company names are the property of their respective owners." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "جميع العلامات التجارية وعلامات الخدمة وأسماء الشركات هي ملك لأصحابها المعنيين."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All trademarks, service marks, and company names are the property of their respective owners."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todas las marcas comerciales, marcas de servicio y nombres de empresas son propiedad de sus respectivos titulares."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تمامی علائم تجاری، علائم خدماتی و نام‌های شرکت‌ها متعلق به صاحبان مربوطه آن‌ها است."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Все товарные знаки, знаки обслуживания и названия компаний являются собственностью их владельцев."
          }
        },
        "tk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ähli haryt nyşanlary, hyzmat nyşanlary we kompaniýa atlary degişli eýeleriniň emlägidir."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tüm ticari markalar, hizmet markaları ve şirket adları ilgili sahiplerinin mülkiyetindedir."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tất cả các nhãn hiệu, nhãn hiệu dịch vụ và tên công ty là tài sản của chủ sở hữu tương ứng."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有商标、服务标识和公司名称均为其各自所有者的财产。"
          }
        }
      }
    },
