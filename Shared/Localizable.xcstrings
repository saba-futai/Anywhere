    "Invalid fingerprint. Must be a 64-character hex string, or it already exists." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بصمة غير صالحة. يجب أن تكون سلسلة سداسية عشرية مكونة من 64 حرفًا، أو أنها موجودة بالفعل."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Invalid fingerprint. Must be a 64-character hex string, or it already exists."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Huella digital no válida. Debe ser una cadena hexadecimal de 64 caracteres, o ya existe."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اثر انگشت نامعتبر. باید یک رشته هگزادسیمال ۶۴ کاراکتری باشد، یا قبلاً وجود دارد."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Недействительный отпечаток. Должна быть шестнадцатеричная строка из 64 символов, или он уже существует."
          }
        },
        "tk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nädogry barlag belgisi. 64 belgili onaltylyk setir bolmaly ýa-da eýýäm bar."
