    "Add at least 2 proxies to form a chain.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضف على الأقل بروكسيين لتشكيل سلسلة."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add at least 2 proxies to form a chain."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agrega al menos 2 proxies para formar una cadena."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "حداقل ۲ پروکسی اضافه کنید تا یک زنجیره بسازید."
          }
        },
        "my": {
          "stringUnit": {
            "state": "translated",
            "value": "ချိတ်ဆက်မှုတစ်ခုဖွဲ့စည်းရန် ပရောက်စီအနည်းဆုံး ၂ ခုထည့်ပါ။"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавьте не менее 2 прокси для создания цепочки."
          }
        },
        "tk": {
          "stringUnit": {
            "state": "translated",
            "value": "Zynjyr döretmek üçin azyndan 2 proksi goşuň."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thêm ít nhất 2 proxy để tạo chuỗi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "至少添加 2 个代理以组成链式代理。"
          }
        }
      }
    },
