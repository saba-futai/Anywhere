    "Route traffic to your home country directly, bypassing the proxy for faster local access." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "وجّه حركة المرور إلى بلدك مباشرة، متجاوزًا البروكسي للوصول المحلي الأسرع."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Route traffic to your home country directly, bypassing the proxy for faster local access."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dirige el tráfico a tu país directamente, evitando el proxy para un acceso local más rápido."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ترافیک به کشور خود را مستقیماً هدایت کنید و پروکسی را برای دسترسی سریع‌تر دور بزنید."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Направляйте трафик в вашу страну напрямую, минуя прокси для более быстрого локального доступа."
          }
        },
        "tk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ýerli elýeterliligi çaltlaşdyrmak üçin proksi aýlanyp, traffigi öz ýurduňyza gönüden-göni ugrugyň."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yerel erişimi hızlandırmak için trafiği proxy'yi atlayarak doğrudan kendi ülkenize yönlendirin."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Định tuyến lưu lượng đến quốc gia của bạn trực tiếp, bỏ qua proxy để truy cập nội địa nhanh hơn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将访问本国的流量直连，绕过代理以获得更快的本地访问速度。"
          }
        }
      }
    },
