        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vân tay không hợp lệ. Phải là chuỗi hex 64 ký tự, hoặc đã tồn tại."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
