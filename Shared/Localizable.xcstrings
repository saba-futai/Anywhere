    "Anywhere is an independent project and is not affiliated with, endorsed by, or sponsored by any of the companies listed below." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anywhere هو مشروع مستقل وليس تابعًا لأي من الشركات المذكورة أدناه أو معتمدًا أو مدعومًا منها."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anywhere is an independent project and is not affiliated with, endorsed by, or sponsored by any of the companies listed below."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anywhere es un proyecto independiente y no está afiliado, respaldado ni patrocinado por ninguna de las empresas que se indican a continuación."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anywhere یک پروژه مستقل است و هیچ‌گونه وابستگی، تأیید یا حمایت مالی از سوی شرکت‌های ذکر شده در زیر ندارد."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anywhere — независимый проект, не связанный ни с одной из перечисленных ниже компаний и не одобренный или спонсируемый ими."
          }
        },
        "tk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anywhere garaşsyz taslamadyr we aşakda görkezilen kompaniýalaryň hiç biri bilen baglanyşykly, goldanýan ýa-da maliýeleşdirilýän däldir."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anywhere bağımsız bir projedir ve aşağıda listelenen şirketlerin hiçbiriyle ilişkili değildir, onlar tarafından onaylanmaz veya desteklenmez."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anywhere là một dự án độc lập, không liên kết, được xác nhận hay tài trợ bởi bất kỳ công ty nào được liệt kê dưới đây."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anywhere 是一个独立项目，与以下列出的任何公司无关，未获其认可或赞助。"
          }
        }
      }
    },
